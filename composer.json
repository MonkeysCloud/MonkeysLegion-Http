{
  "name": "monkeyscloud/monkeyslegion-http",
  "description": "High-performance PSR-7/PSR-15 HTTP message implementations, middleware, and SAPI emitter for the MonkeysLegion framework.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "psr/http-message": "^2.0",
    "psr/http-server-middleware": "^1.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-factory": "^1.1",
    "psr/simple-cache": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "psr/log": "^3.0"
  },
  "suggest": {
    "psr/log": "^3.0 — Required for ErrorHandler PSR-3 logging"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Http\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Http\\Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-2.x-dev": "2.0.x-dev"
    }
  }
}
